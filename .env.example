# Copy to .env and adjust as needed.
# All values are optional; defaults shown match the values in compose.

# Public port the frontend listens on.
PUBLIC_PORT=3000

# Upload hardening caps (backend).
PALADINS_ANALYZER_MAX_FILE_BYTES=1048576      # 1 MiB per file
PALADINS_ANALYZER_MAX_FILES=10                 # per request
PALADINS_ANALYZER_MAX_TOTAL_BYTES=6291456      # 6 MiB aggregate per request
PALADINS_ANALYZER_PARSE_TIMEOUT=5.0            # seconds per file
